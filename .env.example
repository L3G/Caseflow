# Caseflow runtime configuration.
# Copy to `.env` (which is gitignored) and edit as needed.

# Mock = offline deterministic fixtures (no API key). OpenAI = real API calls.
LLM_PROVIDER=Mock

# Required only when LLM_PROVIDER=OpenAI.
OPENAI_API_KEY=

# Tiered model routing — see DESIGN §1.
# Nano tier: planner + document classification (JSON ranking / labeling).
LLM_MODEL_NANO=gpt-5.4-nano
# Mini tier: bank-statement extraction + client-email drafting (vision / generation).
LLM_MODEL_MINI=gpt-5.4-mini

# Extractions below this confidence flag the case instead of advancing state.
LLM_CONFIDENCE_THRESHOLD=0.70

# Stop conditions for one agent run — see DESIGN §7.
AGENT_MAX_STEPS=8
AGENT_MAX_DURATION_SECONDS=25
