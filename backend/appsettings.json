{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Caseflow": "Data Source=caseflow.db"
  },
  "Storage": {
    "DocumentsPath": "documents"
  },
  "Llm": {
    "Provider": "Mock",
    "ApiKey": "",
    "Model": {
      "Nano": "gpt-5.4-nano",
      "Mini": "gpt-5.4-mini"
    },
    "ConfidenceThreshold": 0.70
  },
  "Agent": {
    "MaxStepsPerRun": 8,
    "MaxRunDurationSeconds": 25
  }
}
